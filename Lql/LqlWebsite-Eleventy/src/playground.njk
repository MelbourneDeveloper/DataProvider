---
layout: layouts/base.njk
title: "LQL Playground - Interactive Transpiler"
description: "Try Lambda Query Language and see how it transpiles to PostgreSQL or SQL Server in real time."
---

<section class="playground">
  <div class="container">
    <div class="section-header">
      <h2>LQL Playground</h2>
      <p>Try Lambda Query Language and see how it transpiles to PostgreSQL or SQL Server</p>
    </div>

    <div id="playground-app">
      <div class="playground-content">
        <div class="playground-panel">
          <h3>LQL Input</h3>
          <div class="playground-controls">
            <select id="dialect-selector" class="dialect-selector">
              <option value="PostgreSQL">PostgreSQL</option>
              <option value="SqlServer">SQL Server</option>
            </select>
            <button id="convert-btn" class="convert-btn">Convert to SQL</button>
          </div>
          <textarea id="lql-input" class="lql-input" placeholder="Enter your LQL query here...

Example:
users |> select(users.id, users.name, users.email)"></textarea>
        </div>

        <div class="playground-panel">
          <h3 id="output-title">PostgreSQL Output</h3>
          <div id="sql-output" class="sql-output">Enter LQL code and click 'Convert to SQL' to see the result.</div>
          <div id="error-message" class="error-message" style="display: none;"></div>
        </div>
      </div>

      <div class="playground-panel">
        <h3>Example Queries</h3>
        <p style="color: var(--text-secondary); margin-bottom: var(--space-4);">Click any example to load it into the editor:</p>
        <div class="example-buttons">
          <button class="example-btn" data-example="simple">Simple Select</button>
          <button class="example-btn" data-example="join">Join Tables</button>
          <button class="example-btn" data-example="filter">Filter Data</button>
          <button class="example-btn" data-example="aggregate">Aggregation</button>
          <button class="example-btn" data-example="complex">Complex Query</button>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="/assets/js/playground.js"></script>
