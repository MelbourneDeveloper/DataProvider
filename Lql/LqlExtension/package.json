{
  "name": "lql-language-support",
  "displayName": "Lambda Query Language (LQL)",
  "description": "Language support for Lambda Query Language with syntax highlighting, IntelliSense, and error checking",
  "version": "0.1.0",
  "publisher": "lql-team",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "lql",
    "lambda",
    "query",
    "functional",
    "sql",
    "database"
  ],
  "galleryBanner": {
    "color": "#1C1C1C",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/lambda-query-language"
  },
  "bugs": {
    "url": "https://github.com/your-org/lambda-query-language/issues"
  },
  "homepage": "https://github.com/your-org/lambda-query-language#readme",
  "activationEvents": [
    "onLanguage:lql"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lql",
        "aliases": [
          "Lambda Query Language",
          "lql"
        ],
        "extensions": [
          ".lql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "lql",
        "scopeName": "source.lql",
        "path": "./syntaxes/lql.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "lql",
        "path": "./snippets/lql.json"
      }
    ],
    "themes": [
      {
        "label": "LQL Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/lql-dark.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "LQL Configuration",
      "properties": {
        "lql.languageServer.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the LQL language server"
        },
        "lql.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Path to a local lql-lsp binary. When set, skips the GitHub download and uses this binary instead."
        },
        "lql.database.connectionString": {
          "type": "string",
          "default": "",
          "description": "Database connection string. SQLite: path to .db/.sqlite file. PostgreSQL: libpq-style or Npgsql-style connection string."
        },
        "lql.ai.provider": {
          "type": "string",
          "enum": [
            "",
            "ollama",
            "test"
          ],
          "default": "",
          "description": "AI completion provider. 'ollama' for local Ollama, 'test' for deterministic test completions."
        },
        "lql.ai.endpoint": {
          "type": "string",
          "default": "http://localhost:11434/api/generate",
          "description": "AI provider API endpoint URL."
        },
        "lql.ai.model": {
          "type": "string",
          "default": "qwen2.5-coder:1.5b",
          "description": "AI model identifier."
        },
        "lql.languageServer.trace": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server"
        },
        "lql.validation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable LQL validation"
        },
        "lql.formatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable LQL code formatting"
        }
      }
    },
    "commands": [
      {
        "command": "lql.formatDocument",
        "title": "Format LQL Document",
        "category": "LQL"
      },
      {
        "command": "lql.validateDocument",
        "title": "Validate LQL Document",
        "category": "LQL"
      },
      {
        "command": "lql.showCompiledSql",
        "title": "Show Compiled SQL",
        "category": "LQL"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == lql",
          "command": "lql.formatDocument",
          "group": "1_modification"
        },
        {
          "when": "resourceLangId == lql",
          "command": "lql.showCompiledSql",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "lql.formatDocument",
          "when": "resourceLangId == lql"
        },
        {
          "command": "lql.validateDocument",
          "when": "resourceLangId == lql"
        },
        {
          "command": "lql.showCompiledSql",
          "when": "resourceLangId == lql"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src",
    "fmt": "npx prettier --write .",
    "fmt:check": "npx prettier --check .",
    "test": "node ./out/test/runTest.js",
    "test:coverage": "npm run compile && rm -rf out-cov && nyc instrument out out-cov && rm -rf out && mv out-cov out && node ./out/test/runTest.js; STATUS=$?; nyc report --reporter=json-summary --reporter=text; exit $STATUS",
    "test:lsp": "npm run compile && mocha ./out/test/suite/lsp-protocol.test.js --timeout 30000",
    "test:vsix": "npm run compile && npm run package && mocha ./out/test/suite/vsix-packaging.test.js --ui tdd --timeout 30000",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@vscode/test-electron": "^2.2.0",
    "eslint": "^9.0.0",
    "glob": "^8.0.3",
    "mocha": "^10.2.0",
    "nyc": "^18.0.0",
    "prettier": "^3.0.0",
    "typescript": "^4.9.4",
    "typescript-eslint": "^8.0.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "ts-node": "^10.9.2",
    "vscode-languageclient": "^8.0.2"
  }
}
