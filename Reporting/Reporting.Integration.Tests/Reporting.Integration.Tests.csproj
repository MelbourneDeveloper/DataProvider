<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Library</OutputType>
    <IsTestProject>true</IsTestProject>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Reporting.Integration.Tests</RootNamespace>
    <NoWarn>CA1515;CA2100;CS1591;CA1707;CA1056</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.8.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.0" />
    <PackageReference Include="Microsoft.Playwright" Version="1.50.0" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.3" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Reporting.Api\Reporting.Api.csproj" />
    <ProjectReference Include="..\Reporting.Engine\Reporting.Engine.csproj" />
    <ProjectReference Include="..\..\Migration\Nimblesite.DataProvider.Migration.Core\Nimblesite.DataProvider.Migration.Core.csproj" />
    <ProjectReference Include="..\..\Migration\Nimblesite.DataProvider.Migration.SQLite\Nimblesite.DataProvider.Migration.SQLite.csproj" />
    <ProjectReference Include="..\..\Lql\Nimblesite.Lql.Core\Nimblesite.Lql.Core.csproj" />
    <ProjectReference Include="..\..\Lql\Nimblesite.Lql.SQLite\Nimblesite.Lql.SQLite.csproj" />
    <ProjectReference Include="..\..\Other\Nimblesite.Sql.Model\Nimblesite.Sql.Model.csproj" />
  </ItemGroup>

  <!-- Copy React renderer wwwroot for Playwright tests -->
  <ItemGroup>
    <None
      Include="..\Reporting.React\wwwroot\**\*"
      CopyToOutputDirectory="PreserveNewest"
      LinkBase="wwwroot"
    />
  </ItemGroup>

  <!-- Copy test report definitions and schema -->
  <ItemGroup>
    <Content Include="Reports\*.report.json" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="*.yaml" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="xunit.runner.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- Download React vendor files if Reporting.React has not been built yet -->
  <PropertyGroup>
    <ReactVendorDir>$(MSBuildProjectDirectory)\..\Reporting.React\wwwroot\js\vendor</ReactVendorDir>
  </PropertyGroup>
  <Target
    Name="EnsureReactVendorFiles"
    BeforeTargets="Build"
    Condition="!Exists('$(ReactVendorDir)\react.development.js')"
  >
    <Message
      Importance="high"
      Text="[E2E Tests] Downloading React vendor files for Playwright tests..."
    />
    <MakeDir Directories="$(ReactVendorDir)" />
    <DownloadFile
      SourceUrl="https://unpkg.com/react@18/umd/react.development.js"
      DestinationFolder="$(ReactVendorDir)"
      DestinationFileName="react.development.js"
    />
    <DownloadFile
      SourceUrl="https://unpkg.com/react-dom@18/umd/react-dom.development.js"
      DestinationFolder="$(ReactVendorDir)"
      DestinationFileName="react-dom.development.js"
    />
    <Message Importance="high" Text="[E2E Tests] React vendor files downloaded successfully." />
  </Target>
</Project>
