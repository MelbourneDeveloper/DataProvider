icd10am_code
|> join(icd10am_category, on = icd10am_code.CategoryId = icd10am_category.Id)
|> join(icd10am_block, on = icd10am_category.BlockId = icd10am_block.Id)
|> join(icd10am_chapter, on = icd10am_block.ChapterId = icd10am_chapter.Id)
|> filter(fn(row) => row.icd10am_code.Code LIKE @searchTerm or row.icd10am_code.ShortDescription LIKE @searchTerm or row.icd10am_code.LongDescription LIKE @searchTerm)
|> select(icd10am_code.Id, icd10am_code.Code, icd10am_code.ShortDescription, icd10am_code.LongDescription, icd10am_code.Billable, icd10am_category.CategoryCode, icd10am_block.BlockCode, icd10am_chapter.ChapterNumber, icd10am_chapter.Title AS ChapterTitle)
|> order_by(icd10am_code.Code)
|> limit(@limit)
