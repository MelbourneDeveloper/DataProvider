icd10am_code_embedding
|> join(icd10am_code, on = icd10am_code_embedding.CodeId = icd10am_code.Id)
|> select(icd10am_code_embedding.Id, icd10am_code_embedding.CodeId, icd10am_code_embedding.Embedding, icd10am_code_embedding.EmbeddingModel, icd10am_code.Code, icd10am_code.ShortDescription, icd10am_code.LongDescription)
|> order_by(icd10am_code.Code)
