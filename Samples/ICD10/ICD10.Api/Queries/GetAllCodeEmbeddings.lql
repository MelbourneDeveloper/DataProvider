icd10_code_embedding
|> join(icd10_code, on = icd10_code_embedding.CodeId = icd10_code.Id)
|> select(icd10_code_embedding.Id, icd10_code_embedding.CodeId, icd10_code_embedding.Embedding, icd10_code_embedding.EmbeddingModel, icd10_code.Code, icd10_code.ShortDescription, icd10_code.LongDescription, icd10_code.InclusionTerms, icd10_code.ExclusionTerms, icd10_code.CodeAlso, icd10_code.CodeFirst)
|> order_by(icd10_code.Code)
