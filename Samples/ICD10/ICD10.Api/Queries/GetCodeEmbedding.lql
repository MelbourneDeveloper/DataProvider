icd10_code_embedding
|> join(icd10_code, on = icd10_code_embedding.CodeId = icd10_code.Id)
|> filter(fn(row) => row.icd10_code.Code = @code)
|> select(icd10_code_embedding.Id, icd10_code_embedding.CodeId, icd10_code_embedding.Embedding, icd10_code_embedding.EmbeddingModel, icd10_code_embedding.LastUpdated, icd10_code.Code, icd10_code.ShortDescription)
