-- Get practitioner by ID
-- Parameters: @id
fhir_Practitioner
|> filter(fn(row) => row.fhir_Practitioner.Id = @id)
|> select(fhir_Practitioner.Id, fhir_Practitioner.Identifier, fhir_Practitioner.Active, fhir_Practitioner.NameFamily, fhir_Practitioner.NameGiven, fhir_Practitioner.Qualification, fhir_Practitioner.Specialty, fhir_Practitioner.TelecomEmail, fhir_Practitioner.TelecomPhone)
