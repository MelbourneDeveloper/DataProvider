---
layout: layouts/base.njk
---

{% block head %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "url": "{{ site.url }}{{ page.url }}",
  "datePublished": "{{ date | isoDate }}",
  "dateModified": "{{ dateModified | default(date) | isoDate }}",
  "author": {
    "@type": "Organization",
    "name": "{{ author | default(site.author) }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.name }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.url }}/assets/images/Logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ site.url }}/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": "{{ site.url }}/blog/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{ title }}"
    }
  ]
}
</script>
{% endblock %}

<article class="container" style="padding: var(--space-12) 0;">
  <header class="section-title">
    <h1>{{ title }}</h1>
    <p>
      <time datetime="{{ date | isoDate }}">{{ date | dateFormat }}</time>
      {% if author %} &middot; {{ author }}{% endif %}
    </p>
  </header>

  <div style="max-width: 720px; margin: 0 auto;">
    {{ content | safe }}
    
    {% if tags %}
    <div style="margin-top: var(--space-8);">
      {% for tag in tags %}
      {% if tag != 'post' and tag != 'posts' %}
      <a href="/blog/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a>
      {% endif %}
      {% endfor %}
    </div>
    {% endif %}
  </div>
</article>
