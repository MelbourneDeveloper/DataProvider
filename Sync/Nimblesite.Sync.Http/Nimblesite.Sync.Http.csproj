<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <!--
      This project provides TOOLS for building sync servers (extension methods, DTOs, helpers).
      It is a LIBRARY - not an executable. Reference this and use AddSyncApiServices() + MapSyncEndpoints()
      in YOUR OWN host project.
    -->
    <OutputType>Library</OutputType>
    <RootNamespace>Nimblesite.Sync.Http</RootNamespace>
    <PackageId>Nimblesite.Sync.Http</PackageId>
    <!-- Override Microsoft.NET.Sdk.Web default of IsPackable=false -->
    <IsPackable>true</IsPackable>
    <NoWarn>$(NoWarn);CA1515;CA1307;CA2007;EPC13;CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Nimblesite.Sync.Core/Nimblesite.Sync.Core.csproj" />
    <ProjectReference Include="../Nimblesite.Sync.SQLite/Nimblesite.Sync.SQLite.csproj" />
    <ProjectReference Include="../Nimblesite.Sync.Postgres/Nimblesite.Sync.Postgres.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.3" />
    <PackageReference Include="Npgsql" Version="9.0.2" />
  </ItemGroup>
</Project>
