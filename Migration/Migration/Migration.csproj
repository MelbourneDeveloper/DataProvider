<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <RootNamespace>Migration</RootNamespace>
    <PackageId>Migration</PackageId>
    <Description>YAML-based database schema migration library</Description>
    <!-- Disable warnings that are not relevant -->
    <NoWarn>$(NoWarn);CA2254;CA1720;CA1724;RS1035</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.3" />
    <PackageReference Include="YamlDotNet" Version="16.2.1" />
  </ItemGroup>

</Project>
